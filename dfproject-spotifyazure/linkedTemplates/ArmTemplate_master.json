{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "dfproject-spotifyazure"
		},
		"AzureSqlDatabaseSpotify_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabaseSpotify'"
		},
		"AzureDataLakeStorageSpotify_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorageSpotify'"
		},
		"AzureSqlDatabaseSpotify_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserverakash.database.windows.net"
		},
		"AzureSqlDatabaseSpotify_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "spotifyazuredb"
		},
		"AzureSqlDatabaseSpotify_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminakash"
		},
		"AzureDataLakeStorageSpotify_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifyazure.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "dfproject-spotifyazure_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSqlDatabaseSpotify_password": {
						"value": "[parameters('AzureSqlDatabaseSpotify_password')]"
					},
					"AzureDataLakeStorageSpotify_accountKey": {
						"value": "[parameters('AzureDataLakeStorageSpotify_accountKey')]"
					},
					"AzureSqlDatabaseSpotify_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabaseSpotify_properties_typeProperties_server')]"
					},
					"AzureSqlDatabaseSpotify_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabaseSpotify_properties_typeProperties_database')]"
					},
					"AzureSqlDatabaseSpotify_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabaseSpotify_properties_typeProperties_userName')]"
					},
					"AzureDataLakeStorageSpotify_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorageSpotify_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}